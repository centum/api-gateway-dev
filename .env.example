# Ingress mode: direct (public 443 + CF IP allowlist) or tunnel (cloudflared outbound)
INGRESS_MODE=direct

# Activates the compose profile matching INGRESS_MODE.
# DO NOT edit directly — always keep it equal to INGRESS_MODE above.
# (Exists because docker compose reads COMPOSE_PROFILES from .env natively,
# while Makefile only needs INGRESS_MODE. This keeps `docker compose` commands
# working without going through the Makefile.)
COMPOSE_PROFILES=${INGRESS_MODE}

# Base domain for all services (e.g. example.com)
DOMAIN=example.com

# Email for Let's Encrypt notifications (direct mode only)
ACME_EMAIL=you@example.com

# Cloudflare API Token with Zone:DNS:Edit + Zone:Zone:Read permissions (direct mode only)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=

# Traefik dashboard basic-auth credentials (bcrypt)
# Generate with: htpasswd -nbB admin 'YourPassword' | sed -e 's/\$/\$\$/g'
# The $$ escaping is required by docker compose to produce a literal $ in the container.
DASHBOARD_AUTH=

# ACME CA server URL (direct mode only)
# DEFAULT: staging (untrusted certs — safe for initial setup and debugging)
# After a successful smoke-test, switch to production and run: make reset-certs && make restart
# Staging:    https://acme-staging-v02.api.letsencrypt.org/directory
# Production: https://acme-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# Traefik log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Subdomain for the Traefik dashboard
DASHBOARD_SUBDOMAIN=traefik

# Host ports to bind
HTTP_PORT=80
HTTPS_PORT=443

# Docker network name shared by all services
NETWORK_NAME=traefik_webgateway

# cf-ip-updater (sidecar, direct mode only)
# How often to refresh Cloudflare IP ranges. Supports GNU sleep suffixes: s, m, h, d (e.g. 7d, 24h, 3600)
CF_IPS_UPDATE_INTERVAL=7d
# Alpine image tag for the cf-ip-updater sidecar. Pin for reproducibility.
CF_IPS_UPDATER_IMAGE=alpine:3.20

# cloudflared tunnel (tunnel mode only)
# Token from CF Zero Trust dashboard (Networks -> Tunnels -> your tunnel -> Install connector).
# See docs/ingress-tunnel.md for step-by-step setup. Run `make init-tunnel` for a quick guide.
TUNNEL_TOKEN=
# cloudflared image tag. Pin for reproducibility.
CLOUDFLARED_IMAGE_TAG=latest
